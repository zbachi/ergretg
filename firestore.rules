rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - displayName: string (optional)
    //   - email: string (optional)
    //   - currentDay: int (required) - 1-90
    //   - niche: string (optional)
    //   - createdAt: timestamp (optional)
    //   - completedTasks: list (optional)
    //
    // Collection: videos
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - Owner UID
    //   - topic: string (required)
    //   - status: string (required) - idea, script, voiceover, editing, thumbnail, posted
    //   - idea: map (optional)
    //   - script: string (optional)
    //   - stats: map (optional)
    //   - feedback: string (optional)
    //   - createdAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'currentDay']) &&
             data.uid is string &&
             data.currentDay is int && data.currentDay >= 1 && data.currentDay <= 90;
    }

    function isValidVideo(data) {
      return data.keys().hasAll(['userId', 'topic', 'status']) &&
             data.userId is string &&
             data.topic is string && data.topic.size() > 0 && data.topic.size() < 500 &&
             data.status in ['idea', 'script', 'voiceover', 'editing', 'thumbnail', 'posted'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /videos/{videoId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidVideo(request.resource.data);
      allow update: if isDocOwner() && isValidVideo(request.resource.data);
      allow delete: if isDocOwner();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
